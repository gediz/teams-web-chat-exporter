{
  "name": "teams-web-chat-exporter",
  "version": "1.5.2",
  "description": "Export Microsoft Teams web chat conversations to JSON, CSV, HTML, TXT, or PDF",
  "license": "MIT",
  "packageManager": "pnpm@10.23.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "build:safari": "wxt build -b safari",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "zip:safari": "wxt zip -b safari",
    "check": "node scripts/check-i18n.mjs && node scripts/check-vendor-hashes.mjs && svelte-check --tsconfig ./tsconfig.json",
    "check:i18n": "node scripts/check-i18n.mjs",
    "postinstall": "wxt prepare && node scripts/vendor-twemoji.mjs"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@twemoji/svg": "^15.0.0",
    "fflate": "^0.8.1",
    "harfbuzzjs": "^0.10.3",
    "lucide-svelte": "^0.554.0",
    "pdf-lib": "^1.17.1",
    "vanilla-calendar-pro": "^3.0.5",
    "wxt": "^0.19.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/chrome": "^0.0.268",
    "@types/node": "^22.0.0",
    "svelte": "^5.43.14",
    "svelte-check": "^4.3.4",
    "svgo": "^4.0.1"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.4.0"
    }
  }
}
