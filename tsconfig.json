{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    // Base @tsconfig/svelte pins es2017; Error({ cause }) needs the
    // ES2022 lib types. Type-check only: vite/esbuild transpiles with
    // its own target, so the shipped bundles are unaffected.
    "target": "ES2022",
    "strict": true,
    "baseUrl": ".",
    "allowJs": false,
    "checkJs": false,
    "types": [
      "svelte",
      "chrome",
      "vite/client"
    ],
    "paths": {
      "@/*": [
        "src/*"
      ],
      "~/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "wxt.config.ts",
    "svelte.config.js",
    "svelte.config.ts"
  ],
  "files": [
    "./svelte.d.ts"
  ]
}