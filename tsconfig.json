{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    // Base @tsconfig/svelte pins target es2017, whose lib predates
    // Error({ cause }). Widen only `lib` for the newer TYPE declarations;
    // do NOT raise `target`: esbuild derives class-field emit semantics
    // (useDefineForClassFields) from it, and raising it to ES2022 was
    // measured to change the shipped bundle bytes.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "baseUrl": ".",
    "allowJs": false,
    "checkJs": false,
    "types": [
      "svelte",
      "chrome",
      "vite/client"
    ],
    "paths": {
      "@/*": [
        "src/*"
      ],
      "~/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "wxt.config.ts",
    "svelte.config.js",
    "svelte.config.ts"
  ],
  "files": [
    "./svelte.d.ts"
  ]
}